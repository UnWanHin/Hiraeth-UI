COMPOSE_PROJECT_NAME=hiraeth-ui

# Hiraeth binds to localhost by default. Keep this behind Cloudflare Tunnel,
# Nginx, Caddy, or another reverse proxy instead of exposing it directly.
HIRAETH_HOST=127.0.0.1
HIRAETH_PORT=8790
HIRAETH_CONTAINER_NAME=hiraeth-ui

# Stops and removes an old container named studio-portal before first Hiraeth UI start.
HIRAETH_MIGRATE_LEGACY=true

# In-container paths used by docker-compose.yml.
PORTAL_CONFIG=/app/config/portal.local.json
BENCHMARK_DATA=/app/data/benchmark.local.json
BENCHMARK_STATUS=/app/data/benchmark-status.local.json
